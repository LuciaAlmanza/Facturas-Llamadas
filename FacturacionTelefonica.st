Object subclass: #Cliente	instanceVariableNames: 'nombre numeroTelefono'	classVariableNames: ''	poolDictionaries: ''	category: 'FacturacionTelefonica'!!Cliente methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:23'!inicializarConNombre: unNombre numeroTelefono: unNumero    nombre := unNombre.    numeroTelefono := unNumero.! !!Cliente methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:27'!nombre    ^ nombre.! !!Cliente methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:27'!numeroTelefono    ^ numeroTelefono.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Cliente class	instanceVariableNames: ''!!Cliente class methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:29'!nombre: unNombre numeroTelefono: unNumero    ^ self new        inicializarConNombre: unNombre numeroTelefono: unNumero;        yourself.! !Object subclass: #Factura	instanceVariableNames: 'cliente abonoMensual llamadas'	classVariableNames: ''	poolDictionaries: ''	category: 'FacturacionTelefonica'!!Factura methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:45'!cliente: unCliente abonoMensual: unAbono llamadas: unasLlamadas    ^ self new        inicializarConCliente: unCliente        abonoMensual: unAbono        llamadas: unasLlamadas;        yourself.! !!Factura methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 19:27'!consumoPorLlamadas    | total |    total := 0.    llamadas do: [ :unaLlamada |        total := total + unaLlamada costo    ].    ^ total.! !!Factura methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:44'!imprimir    Transcript clear.    Transcript show: 'FACTURA MENSUAL'; cr.    Transcript show: '-------------------------'; cr.    Transcript show: 'Cliente: ', cliente nombre; cr.    Transcript show: 'Telefono: ', cliente numeroTelefono; cr.    Transcript show: 'Abono mensual: $', abonoMensual asString; cr; cr.    Transcript show: 'Detalle de llamadas:'; cr.    llamadas do: [ :unaLlamada |        Transcript            show: unaLlamada destino;            show: ' | Duracion: ';            show: unaLlamada duracion asString;            show: ' min | Costo: $';            show: unaLlamada costo asString;            cr.    ].    Transcript cr.    Transcript show: 'Consumo por llamadas: $', self consumoPorLlamadas asString; cr.    Transcript show: 'Total a pagar: $', self total asString; cr.! !!Factura methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:44'!inicializarConCliente: unCliente abonoMensual: unAbono llamadas: unasLlamadas    cliente := unCliente.    abonoMensual := unAbono.    llamadas := unasLlamadas.! !!Factura methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:44'!total    ^ abonoMensual + self consumoPorLlamadas.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Factura class	instanceVariableNames: ''!!Factura class methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 19:21'!cliente: unCliente abonoMensual: unAbono llamadas: unasLlamadas    ^ self new        inicializarConCliente: unCliente        abonoMensual: unAbono        llamadas: unasLlamadas;        yourself.! !Object subclass: #Llamada	instanceVariableNames: 'duracion fechaHora destino tarifa'	classVariableNames: ''	poolDictionaries: ''	category: 'FacturacionTelefonica'!!Llamada methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:35'!costo    ^ tarifa calcularCostoPara: self.! !!Llamada methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:35'!destino    ^ destino.! !!Llamada methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:35'!duracion    ^ duracion.! !!Llamada methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:35'!fechaHora    ^ fechaHora.! !!Llamada methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:34'!inicializarConDuracion: unaDuracion fechaHora: unaFechaHora destino: unDestino tarifa: unaTarifa    duracion := unaDuracion.    fechaHora := unaFechaHora.    destino := unDestino.    tarifa := unaTarifa.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Llamada class	instanceVariableNames: ''!!Llamada class methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 19:12'!duracion: unaDuracion fechaHora: unaFechaHora destino: unDestino tarifa: unaTarifa    ^ self new        inicializarConDuracion: unaDuracion        fechaHora: unaFechaHora        destino: unDestino        tarifa: unaTarifa;        yourself.! !Object subclass: #Tarifa	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'FacturacionTelefonica'!!Tarifa methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:37'!calcularCostoPara: unaLlamada    self subclassResponsibility.! !Tarifa subclass: #TarifaInternacional	instanceVariableNames: 'preciosPorPais'	classVariableNames: ''	poolDictionaries: ''	category: 'FacturacionTelefonica'!!TarifaInternacional methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:40'!calcularCostoPara: unaLlamada    ^ unaLlamada duracion        * (self precioPorMinutoPara: unaLlamada destino).! !!TarifaInternacional methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:40'!conPrecios: unDiccionario    ^ self new        inicializarConPrecios: unDiccionario;        yourself.! !!TarifaInternacional methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:40'!inicializarConPrecios: unDiccionario    preciosPorPais := unDiccionario.! !!TarifaInternacional methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:40'!precioPorMinutoPara: unPais    ^ preciosPorPais        at: unPais        ifAbsent: [ self error: 'No existe tarifa para ese pais' ].! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!TarifaInternacional class	instanceVariableNames: ''!!TarifaInternacional class methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 19:10'!conPrecios: unDiccionario    ^ self new        inicializarConPrecios: unDiccionario;        yourself.! !Tarifa subclass: #TarifaLocal	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'FacturacionTelefonica'!!TarifaLocal methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:38'!calcularCostoPara: unaLlamada    ^ unaLlamada duracion * (self precioPorMinutoPara: unaLlamada).! !!TarifaLocal methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:38'!esFinDeSemana: unaLlamada    | dia |    dia := unaLlamada fechaHora dayOfWeek.    ^ dia = 6 or: [ dia = 7 ].! !!TarifaLocal methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:38'!esHorarioPico: unaLlamada    | hora |    hora := unaLlamada fechaHora hour.    ^ hora >= 8 and: [ hora < 20 ].! !!TarifaLocal methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:38'!precioPorMinutoPara: unaLlamada    (self esFinDeSemana: unaLlamada) ifTrue: [ ^ 0.10 ].    (self esHorarioPico: unaLlamada) ifTrue: [ ^ 0.20 ].    ^ 0.10.! !Tarifa subclass: #TarifaNacional	instanceVariableNames: 'preciosPorLocalidad'	classVariableNames: ''	poolDictionaries: ''	category: 'FacturacionTelefonica'!!TarifaNacional methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:39'!calcularCostoPara: unaLlamada    ^ unaLlamada duracion        * (self precioPorMinutoPara: unaLlamada destino).! !!TarifaNacional methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:40'!conPrecios: unDiccionario    ^ self new        inicializarConPrecios: unDiccionario;        yourself.! !!TarifaNacional methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:39'!inicializarConPrecios: unDiccionario    preciosPorLocalidad := unDiccionario.! !!TarifaNacional methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 18:40'!precioPorMinutoPara: unaLocalidad    ^ preciosPorLocalidad        at: unaLocalidad        ifAbsent: [ self error: 'No existe tarifa para esa localidad' ].! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!TarifaNacional class	instanceVariableNames: ''!!TarifaNacional class methodsFor: 'as yet unclassified' stamp: 'Lucia Almanza 5/16/2026 19:10'!conPrecios: unDiccionario    ^ self new        inicializarConPrecios: unDiccionario;        yourself.! !